# =====================================================
# OKITO V2 — Template d'environnement
# =====================================================
# Copie ce fichier en `.env` (racine + apps/api/.env) et remplis les valeurs
# selon le guide infra/SETUP.md. Lance `pnpm check:env` pour valider.
# =====================================================

# --- App ----------------------------------------------------------------------
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3000


# --- Database (Supabase) ------------------------------------------------------
# Supabase Studio → Project Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://postgres:PASSWORD@db.XXX.supabase.co:5432/postgres
SUPABASE_URL=https://XXX.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# Supabase Studio → Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=ton-jwt-secret-min-16-chars


# --- LLM (Gemini via Google AI Studio) ---------------------------------------
# aistudio.google.com → API Keys
GEMINI_API_KEY=AIza...
LLM_MODEL=gemini-2.5-flash
LLM_FALLBACK_MODEL=gemini-2.5-pro
LLM_TIMEOUT_MS=15000
LLM_RETRY_MAX=3


# --- Voix (Vapi) --------------------------------------------------------------
# dashboard.vapi.ai → Account → API Keys
VAPI_API_KEY=
VAPI_PUBLIC_KEY=
VAPI_ASSISTANT_ID=


# --- Email (Resend) -----------------------------------------------------------
# resend.com → API Keys → Create
RESEND_API_KEY=re_...
# Adresse vérifiée chez Resend (domain auth obligatoire)
RESEND_FROM_EMAIL=OKITO <bot@tondomaine.com>


# --- WhatsApp / SMS (Twilio) --------------------------------------------------
# console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
# Sandbox WhatsApp Twilio (joindre par envoi de "join <code>" depuis WhatsApp)
TWILIO_WHATSAPP_FROM=+14155238886
# Numéro SMS (différent possible du WhatsApp)
TWILIO_SMS_FROM=
# Mettre "true" en prod pour vérifier X-Twilio-Signature sur les webhooks
TWILIO_VALIDATE_WEBHOOK=false


# --- WhatsApp alternatif (360dialog, à activer si >1000 msg/mois) ------------
# Hub 360dialog → Settings → API Key (format "D3-...")
# Si défini, supplante Twilio pour le canal WhatsApp.
THREE60DIALOG_API_KEY=


# --- Jobs (Inngest cloud) -----------------------------------------------------
# app.inngest.com → ton app → Manage → Signing Keys
INNGEST_SIGNING_KEY=signkey-prod-...
INNGEST_EVENT_KEY=


# --- Billing (Stripe) ---------------------------------------------------------
# dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
# Developers → Webhooks → Add endpoint → "Signing secret"
STRIPE_WEBHOOK_SECRET=whsec_...


# --- Admin -------------------------------------------------------------------
# UUIDs Supabase Auth des admins (Studio → Authentication → Users → UID).
# Plusieurs admins = séparer par virgule sans espace.
ADMIN_USER_IDS=00000000-0000-4000-8000-000000000000


# --- Observability -----------------------------------------------------------
# sentry.io → Settings → Projects → ton-projet → Client Keys (DSN)
SENTRY_DSN=
