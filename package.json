{
  "name": "okito-v2",
  "version": "0.0.0",
  "private": true,
  "description": "OKITO V2 — SaaS multi-tenant de réservation pour restaurants (moteur conversationnel multi-canal)",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "seed:dev": "tsx scripts/seed-dev.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@okito/db": "workspace:*",
    "@types/node": "^22.10.2",
    "dotenv": "^16.4.7",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "lint-staged": {
    "*.{js,ts,tsx,json}": "biome check --write --no-errors-on-unmatched"
  }
}
