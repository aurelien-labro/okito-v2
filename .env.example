VAPI_API_KEY=
RESEND_API_KEY=

# --- Jobs ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Billing (Phase 5) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- App ---
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3000
